# Pigeon — environment.
# DEV + DEFAULT RUN ON THE MOCK ADAPTER. No key required. No paid calls. Ever.
# The Grok path is implemented but INERT unless a key is present.

# Classifier provider: mock (default) | xai (Grok) | openai | deepseek
LLM_PROVIDER=mock

# Grok (xAI) — OpenAI-compatible, base https://api.x.ai/v1.
# Leave UNSET in dev. Setting this does NOT auto-enable Grok; you must also set LLM_PROVIDER=xai.
# GROK_API_KEY=
# LLM_MODEL_ID=grok-2-1212   # re-verify the current Grok model id the day a key is provisioned

# Ingestion contact UA (politeness header for gov endpoints)
PIGEON_UA=PigeonNews/1.0 (+https://creatusdesign.dev; contact pigeon@creatusdesign.dev)

# ---- MARKETS (v2 scope expansion) ----
# Keyless Treasury yields (2y/10y/30y + 2s10s) are LIVE with no key. These two add the rest of
# the Wall Street gauges (S&P 500, Nasdaq, VIX, WTI oil, Fed funds, Dow). Same red line as Grok:
# the gauge is INERT and never fetched until its key is set; no paid call, free tier only.
# FRED_API_KEY=        # St. Louis Fed (free key, instant) — indices, VIX, oil, Fed funds
# FINNHUB_API_KEY=     # Finnhub (free key) — live index/equity quotes
